SCRIPT_DIR=$(dirname "$(realpath ~/.zshrc)")
DOTFILES_DIR=$(dirname "$SCRIPT_DIR")
source "$DOTFILES_DIR/zsh/.antidote/antidote.zsh"

antidote load "${ZDOTDIR:-$HOME}/.zsh_plugins.txt"

# Tell Zsh to keep both 'path' and 'PATH' arrays bound together and strictly UNIQUE
typeset -U path PATH

# 2. Add our custom dotfile scripts folder
path+=( "$DOTFILES_DIR/scripts" )

# 3. Add App Paths (Only if they actually exist on this machine)
# This prevents Zsh from searching dead paths on fresh system setups
apps_to_load=(
    "/Users/$USER/CEDev/bin"
    "/Users/$USER/.pixi/bin"
    "/Users/$USER/Library/Application Support/Steam/steamapps/common/Blender/Blender.app/Contents/MacOS"
    "/Applications/Inkscape.app/Contents/MacOS"
    "/Applications/KiCad/KiCad.app/Contents/MacOS"
    "/Applications/Wolfram.app/Contents/MacOS"
)

for app_dir in $apps_to_load; do
    if [ -d "$app_dir" ]; then
        path+=( "$app_dir" )
    fi
done

if [ -x "$(which zoxide)" ];
then
    function cd () {
        __zoxide_z "$@"
    }
    eval "$(zoxide init zsh --no-cmd)"
fi

# A safe, isolated function to check your path array
function checkpath() {
    for dir in $path; do
        if [[ -d "$dir" ]]; then
            echo "✅ $dir"
        else
            echo "❌ $dir (Broken)"
        fi
    done
}
