#!/bin/bash

# Soydev LaTeX Project Generator 😎
# Usage: ./ag <project_name>
#        ./ag --make-template
#        ./ag --help

set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
SCRIPT_PATH="$(cd -- "$(dirname -- "$SCRIPT_SOURCE")" && pwd)/$(basename -- "$SCRIPT_SOURCE")"
PAYLOAD_PLACEHOLDER="__AG_BASE64_PAYLOAD__"

show_help() {
  cat <<EOF
Soydev LaTeX Project Generator

Usage:
  $0 <project_name>
  $0 --make-template
  $0 --help

Modes:
  <project_name>   Create a project directory and unpack the embedded template.
  --make-template  Rebuild the embedded template from the current directory and
                   overwrite this script in place.

Template behavior:
  - If the current directory is a git repository, ignored files are excluded.
  - If it is not a git repository, all files in the current directory are
    included except the .git directory if one exists.
EOF
}

usage() {
  echo "🚨 Oops! Please provide a project name."
  show_help
}

unknown_flag() {
  echo "🚨 Error: '$1' is not recognized."
  show_help
  exit 1
}

make_template() {
  local current_dir repo_root repo_prefix script_rel tmp_dir archive_file payload_file template_file final_file

  current_dir="$PWD"

  script_rel=""
  case "$SCRIPT_PATH" in
    "$current_dir"/*) script_rel="${SCRIPT_PATH#"$current_dir/"}" ;;
  esac

  tmp_dir="$(mktemp -d)"
  trap "rm -rf '$tmp_dir'" EXIT

  archive_file="$tmp_dir/current-directory.tar.xz"
  payload_file="$tmp_dir/payload.b64"
  template_file="$tmp_dir/template.sh"
  final_file="$tmp_dir/final.sh"

  if git -C "$current_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    repo_root="$(git -C "$current_dir" rev-parse --show-toplevel)"
    repo_prefix="$(git -C "$current_dir" rev-parse --show-prefix)"

    {
      git -C "$repo_root" ls-files -co --exclude-standard -z \
        | while IFS= read -r -d '' path; do
            case "$path" in
              "$repo_prefix"*) path="${path#"$repo_prefix"}" ;;
              *) continue ;;
            esac

            [ "$path" = "$script_rel" ] && continue
            printf '%s\0' "$path"
          done
    } | tar --null -T - -cJf "$archive_file"
  else
    (
      cd "$current_dir"
      find . \( -path './.git' -o -path './.git/*' \) -prune -o -type f -print0 \
        | while IFS= read -r -d '' path; do
            path="${path#./}"
            [ "$path" = "$script_rel" ] && continue
            printf '%s\0' "$path"
          done
    ) | tar --null -T - -cJf "$archive_file"
  fi

  base64 < "$archive_file" | fold -w 80 > "$payload_file"

  awk -v placeholder="$PAYLOAD_PLACEHOLDER" '
    BEGIN {
      in_payload = 0
      inserted_placeholder = 0
    }

    {
      if (!in_payload) {
        print
        if ($0 ~ /^BASE64_TARXZ=\\$/) {
          in_payload = 1
        }
        next
      }

      if (!inserted_placeholder) {
        print
        print placeholder
        inserted_placeholder = 1
        next
      }

      if ($0 == "\"") {
        print
        in_payload = 0
        inserted_placeholder = 0
      }
    }
  ' "$SCRIPT_PATH" > "$template_file"

  awk -v payload_file="$payload_file" -v placeholder="$PAYLOAD_PLACEHOLDER" '
    BEGIN {
      while ((getline payload_line < payload_file) > 0) {
        payload[payload_count++] = payload_line
      }
      close(payload_file)
    }

    {
      if ($0 == placeholder) {
        for (i = 0; i < payload_count; i++) {
          print payload[i]
        }
        next
      }

      print
    }
  ' "$template_file" > "$final_file"

  mv "$final_file" "$SCRIPT_PATH"
  chmod +x "$SCRIPT_PATH"
  echo "🎉 Refreshed the embedded LaTeX payload in '$SCRIPT_PATH'"
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
  --make-template)
    if [ "$#" -ne 1 ]; then
      usage
      exit 1
    fi

    make_template
    exit 0
    ;;
esac

for arg in "$@"; do
  case "$arg" in
    -h|--help|--make-template)
      ;;
    -* )
      unknown_flag "$arg"
      ;;
  esac
done

if [ "$#" -ne 1 ]; then
  usage
  exit 1
fi

PROJECT_NAME="$1"
BASE64_TARXZ=\
